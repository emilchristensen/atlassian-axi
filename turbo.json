{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:skill": {
      "dependsOn": ["^build"],
      "outputs": ["skills/**"],
      // Never replay: `build:skill -- --check` is a drift GUARD, so a cache
      // hit would report a stale pass. The script is sub-second either way.
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
